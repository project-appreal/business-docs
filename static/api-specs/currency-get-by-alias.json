{
  "openapi": "3.0.0",
  "info": {
    "title": "Get Currency by Alias",
    "version": ""
  },
  "servers": [
    {
      "url": "https://api.appreal.com/api/business/v1",
      "description": "Production"
    },
    {
      "url": "https://dev.appreal.xyz/api/business/v1",
      "description": "Development"
    }
  ],
  "security": [
    {
      "X-API-Key": []
    }
  ],
  "paths": {
    "/currencies/{alias}": {
      "get": {
        "operationId": "CurrencyBusinessController_getByAlias",
        "summary": "Get Currency by Alias",
        "parameters": [
          {
            "name": "alias",
            "required": true,
            "in": "path",
            "description": "Currency alias (e.g., usdt_binance)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Currency retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrencyBusinessResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Currency not available via this API"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          },
          "404": {
            "description": "Currency not found"
          }
        },
        "security": [
          {
            "X-API-Key": []
          }
        ],
        "description": "Retrieves a specific currency by its alias (e.g., `usdt_binance`, `btc_bitcoin`). The alias uniquely identifies a currency on a specific network.\n\n> **Tip:** Use this endpoint to look up currency details when you already know the alias from a previous API response."
      }
    }
  },
  "components": {
    "securitySchemes": {
      "X-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key for business authentication",
        "x-default": "YOUR_API_KEY_HERE"
      }
    },
    "schemas": {
      "CurrencyBusinessResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Currency alias (e.g., usdt_binance) — public identifier"
          },
          "name": {
            "type": "string",
            "description": "Currency name"
          },
          "symbol": {
            "type": "string",
            "description": "Currency symbol (e.g., ETH, USDT)"
          },
          "currencyType": {
            "type": "string",
            "description": "Currency type",
            "enum": [
              "FIAT",
              "CRYPTO"
            ]
          },
          "decimals": {
            "type": "number",
            "description": "Token decimals"
          },
          "contractAddress": {
            "type": "string",
            "description": "Contract address (for tokens)"
          },
          "logo": {
            "type": "string",
            "description": "Currency logo URL"
          },
          "network": {
            "description": "Network the currency is deployed on",
            "allOf": [
              {
                "$ref": "#/components/schemas/BusinessNetworkDto"
              }
            ]
          }
        },
        "required": [
          "id",
          "name",
          "symbol",
          "currencyType",
          "decimals"
        ]
      },
      "BusinessNetworkDto": {
        "type": "object",
        "properties": {
          "chainId": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "networkName": {
            "type": "string"
          },
          "blockchainNetworkType": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "blockExplorerUrl": {
            "type": "string"
          }
        },
        "required": [
          "chainId",
          "network",
          "networkName"
        ]
      }
    }
  }
}