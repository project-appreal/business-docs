{
  "openapi": "3.0.0",
  "info": {
    "title": "List Networks",
    "version": ""
  },
  "servers": [
    {
      "url": "https://api.appreal.com/api/business/v1",
      "description": "Production"
    },
    {
      "url": "https://dev.appreal.xyz/api/business/v1",
      "description": "Development"
    }
  ],
  "security": [
    {
      "X-API-Key": []
    }
  ],
  "paths": {
    "/networks": {
      "get": {
        "operationId": "NetworkBusinessController_getAll",
        "summary": "List Networks",
        "parameters": [
          {
            "name": "isActive",
            "required": false,
            "in": "query",
            "description": "Filter by active status",
            "schema": {
              "default": true,
              "type": "boolean"
            }
          },
          {
            "name": "blockchainType",
            "required": false,
            "in": "query",
            "description": "Filter by blockchain type (EVM, TRON, SOLANA)",
            "schema": {
              "enum": [
                "EVM",
                "SOLANA",
                "TRON",
                "VIRTUAL"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Networks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NetworkBusinessResponseDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        },
        "security": [
          {
            "X-API-Key": []
          }
        ],
        "description": "Returns all supported blockchain networks with their details, including chain ID, blockchain type, and active status.\n\nFilter by `blockchainType` to see only EVM-compatible chains, Solana, or Tron networks."
      }
    }
  },
  "components": {
    "securitySchemes": {
      "X-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key for business authentication",
        "x-default": "YOUR_API_KEY_HERE"
      }
    },
    "schemas": {
      "NetworkBusinessResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Network slug (e.g., arbitrum-one) — public identifier"
          },
          "chainId": {
            "type": "string",
            "description": "Chain ID"
          },
          "network": {
            "type": "string",
            "description": "Network identifier (e.g., ethereum, tron)"
          },
          "networkName": {
            "type": "string",
            "description": "Human-readable network name"
          },
          "blockchainType": {
            "type": "string",
            "description": "Blockchain type (EVM, TRON, SOLANA)",
            "enum": [
              "EVM",
              "SOLANA",
              "TRON",
              "VIRTUAL"
            ]
          },
          "logo": {
            "type": "string",
            "description": "Network logo URL"
          }
        },
        "required": [
          "id",
          "chainId",
          "network",
          "networkName"
        ]
      }
    }
  }
}