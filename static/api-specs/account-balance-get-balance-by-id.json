{
  "openapi": "3.0.0",
  "info": {
    "title": "Get Account Balance",
    "version": ""
  },
  "servers": [
    {
      "url": "https://api.appreal.com/api/business/v1",
      "description": "Production"
    },
    {
      "url": "https://dev.appreal.xyz/api/business/v1",
      "description": "Development"
    }
  ],
  "security": [
    {
      "X-API-Key": []
    }
  ],
  "paths": {
    "/account-balances/{id}": {
      "get": {
        "operationId": "AccountBalanceBusinessController_getBalanceById",
        "summary": "Get Account Balance",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Account balance retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountBalanceBusinessResponseDto"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          },
          "403": {
            "description": "Forbidden - Balance does not belong to business"
          },
          "404": {
            "description": "Account balance not found"
          }
        },
        "security": [
          {
            "X-API-Key": []
          }
        ],
        "description": "Retrieves a specific account balance by its public ID. Returns the current balance amount, currency details, and pending transactions."
      }
    }
  },
  "components": {
    "securitySchemes": {
      "X-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key for business authentication",
        "x-default": "YOUR_API_KEY_HERE"
      }
    },
    "schemas": {
      "AccountBalanceBusinessResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Public balance identifier (CUID2)"
          },
          "amount": {
            "type": "string"
          },
          "amountInWei": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "SUSPENDED",
              "ARCHIVED"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "currency": {
            "$ref": "#/components/schemas/BusinessCurrencyDto"
          }
        },
        "required": [
          "id",
          "amount",
          "status",
          "createdAt",
          "updatedAt"
        ]
      },
      "BusinessCurrencyDto": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "currencyType": {
            "type": "string",
            "enum": [
              "FIAT",
              "CRYPTO"
            ]
          },
          "decimals": {
            "type": "number"
          },
          "paymentDecimals": {
            "type": "number"
          },
          "contractAddress": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "network": {
            "$ref": "#/components/schemas/BusinessNetworkDto"
          }
        },
        "required": [
          "symbol",
          "name"
        ]
      },
      "BusinessNetworkDto": {
        "type": "object",
        "properties": {
          "chainId": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "networkName": {
            "type": "string"
          },
          "blockchainNetworkType": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "blockExplorerUrl": {
            "type": "string"
          }
        },
        "required": [
          "chainId",
          "network",
          "networkName"
        ]
      }
    }
  }
}