{
  "openapi": "3.0.0",
  "info": {
    "title": "Cancel invoice",
    "version": ""
  },
  "servers": [
    {
      "url": "https://api.appreal.com/api/business/v1",
      "description": "Production"
    },
    {
      "url": "https://dev.appreal.xyz/api/business/v1",
      "description": "Development"
    }
  ],
  "security": [
    {
      "X-API-Key": []
    }
  ],
  "paths": {
    "/invoices/{id}/cancel": {
      "post": {
        "operationId": "InvoiceBusinessController_cancel",
        "summary": "Cancel invoice",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Invoice public ID (24-char alphanumeric)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelInvoiceDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invoice cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceBusinessResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - Invoice cannot be cancelled in current status"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          },
          "404": {
            "description": "Invoice not found"
          }
        },
        "tags": [
          "Invoice"
        ],
        "security": [
          {
            "X-API-Key": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "X-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key for business authentication",
        "x-default": "YOUR_API_KEY_HERE"
      }
    },
    "schemas": {
      "CancelInvoiceDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "description": "Reason for cancellation",
            "maxLength": 500
          }
        }
      },
      "InvoiceBusinessResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Public invoice identifier (CUID2)"
          },
          "number": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "paymentStatus": {
            "type": "string"
          },
          "customerEmail": {
            "type": "string"
          },
          "customerName": {
            "type": "string"
          },
          "webhookUrl": {
            "type": "string"
          },
          "redirectUrl": {
            "type": "string"
          },
          "paymentUrl": {
            "type": "string"
          },
          "walletAddress": {
            "type": "string"
          },
          "txHash": {
            "type": "string"
          },
          "sourceAmount": {
            "type": "string"
          },
          "destinationAmount": {
            "type": "string"
          },
          "paidAmount": {
            "type": "string"
          },
          "feeAmount": {
            "type": "string"
          },
          "netAmount": {
            "type": "string"
          },
          "destinationPaidAmount": {
            "type": "string"
          },
          "exchangeRate": {
            "type": "number"
          },
          "expiredAt": {
            "type": "string"
          },
          "reference": {
            "type": "object"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "sourceCurrency": {
            "$ref": "#/components/schemas/BusinessCurrencyDto"
          },
          "destinationCurrency": {
            "$ref": "#/components/schemas/BusinessCurrencyDto"
          }
        },
        "required": [
          "id",
          "number",
          "status",
          "paymentStatus",
          "customerEmail",
          "customerName",
          "destinationAmount",
          "createdAt",
          "updatedAt"
        ]
      },
      "BusinessCurrencyDto": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "currencyType": {
            "type": "string",
            "enum": [
              "FIAT",
              "CRYPTO"
            ]
          },
          "decimals": {
            "type": "number"
          },
          "paymentDecimals": {
            "type": "number"
          },
          "contractAddress": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "network": {
            "$ref": "#/components/schemas/BusinessNetworkDto"
          }
        },
        "required": [
          "symbol",
          "name"
        ]
      },
      "BusinessNetworkDto": {
        "type": "object",
        "properties": {
          "chainId": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "networkName": {
            "type": "string"
          },
          "blockchainNetworkType": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "blockExplorerUrl": {
            "type": "string"
          }
        },
        "required": [
          "chainId",
          "network",
          "networkName"
        ]
      }
    }
  }
}