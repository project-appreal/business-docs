{
  "openapi": "3.0.0",
  "info": {
    "title": "Create Invoice",
    "version": ""
  },
  "servers": [
    {
      "url": "https://api.appreal.com/api/business/v1",
      "description": "Production"
    },
    {
      "url": "https://dev.appreal.xyz/api/business/v1",
      "description": "Development"
    }
  ],
  "security": [
    {
      "X-API-Key": []
    }
  ],
  "paths": {
    "/invoices": {
      "post": {
        "operationId": "InvoiceBusinessController_create",
        "summary": "Create Invoice",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvoiceDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invoice created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceBusinessResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "401": {
            "description": "Unauthorized - Invalid API key"
          }
        },
        "security": [
          {
            "X-API-Key": []
          }
        ],
        "description": "Creates a new payment invoice in PREPARED status. The invoice is not yet active — use the [Activate Invoice](/api/invoice-activate) endpoint to assign a wallet and begin accepting payments.\n\n**Typical flow**: Create Invoice → Activate Invoice → Monitor status via webhooks.\n\n> **Note:** Set a `webhookUrl` to receive real-time status updates. Do not rely solely on polling — use webhooks as the primary notification mechanism."
      }
    }
  },
  "components": {
    "securitySchemes": {
      "X-API-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "API Key for business authentication",
        "x-default": "YOUR_API_KEY_HERE"
      }
    },
    "schemas": {
      "CreateInvoiceDto": {
        "type": "object",
        "properties": {
          "customerEmail": {
            "type": "string",
            "format": "email",
            "description": "Customer email address"
          },
          "customerName": {
            "type": "string",
            "description": "Customer display name"
          },
          "notificationEmail": {
            "type": "string",
            "format": "email",
            "description": "Email to receive payment notifications"
          },
          "reference": {
            "description": "Arbitrary reference string or object to attach to the invoice",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object"
              }
            ]
          },
          "invoice": {
            "type": "object",
            "description": "Invoice amount and currency details",
            "properties": {
              "amount": {
                "type": "number",
                "description": "Invoice amount (must be positive)",
                "example": 10.5
              },
              "sourceCurrency": {
                "type": "string",
                "description": "Source currency symbol or alias (optional)"
              },
              "destinationCurrency": {
                "type": "string",
                "description": "Destination currency symbol or alias"
              }
            },
            "required": [
              "amount",
              "destinationCurrency"
            ]
          },
          "redirectUrl": {
            "type": "string",
            "description": "URL to redirect the customer after payment"
          },
          "nonce": {
            "type": "string",
            "description": "Idempotency key to prevent duplicate invoices"
          },
          "webhookUrl": {
            "type": "string",
            "description": "Webhook URL to receive payment status updates"
          }
        },
        "required": [
          "invoice"
        ]
      },
      "InvoiceBusinessResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Public invoice identifier (CUID2)"
          },
          "number": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "paymentStatus": {
            "type": "string"
          },
          "customerEmail": {
            "type": "string"
          },
          "customerName": {
            "type": "string"
          },
          "webhookUrl": {
            "type": "string"
          },
          "redirectUrl": {
            "type": "string"
          },
          "paymentUrl": {
            "type": "string"
          },
          "walletAddress": {
            "type": "string"
          },
          "txHash": {
            "type": "string"
          },
          "sourceAmount": {
            "type": "string"
          },
          "destinationAmount": {
            "type": "string"
          },
          "paidAmount": {
            "type": "string"
          },
          "feeAmount": {
            "type": "string"
          },
          "netAmount": {
            "type": "string"
          },
          "destinationPaidAmount": {
            "type": "string"
          },
          "exchangeRate": {
            "type": "number"
          },
          "expiredAt": {
            "type": "string"
          },
          "reference": {
            "type": "object"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "sourceCurrency": {
            "$ref": "#/components/schemas/BusinessCurrencyDto"
          },
          "destinationCurrency": {
            "$ref": "#/components/schemas/BusinessCurrencyDto"
          }
        },
        "required": [
          "id",
          "number",
          "status",
          "paymentStatus",
          "customerEmail",
          "customerName",
          "destinationAmount",
          "createdAt",
          "updatedAt"
        ]
      },
      "BusinessCurrencyDto": {
        "type": "object",
        "properties": {
          "symbol": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "currencyType": {
            "type": "string",
            "enum": [
              "FIAT",
              "CRYPTO"
            ]
          },
          "decimals": {
            "type": "number"
          },
          "paymentDecimals": {
            "type": "number"
          },
          "contractAddress": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "network": {
            "$ref": "#/components/schemas/BusinessNetworkDto"
          }
        },
        "required": [
          "symbol",
          "name"
        ]
      },
      "BusinessNetworkDto": {
        "type": "object",
        "properties": {
          "chainId": {
            "type": "string"
          },
          "network": {
            "type": "string"
          },
          "networkName": {
            "type": "string"
          },
          "blockchainNetworkType": {
            "type": "string"
          },
          "logo": {
            "type": "string"
          },
          "blockExplorerUrl": {
            "type": "string"
          }
        },
        "required": [
          "chainId",
          "network",
          "networkName"
        ]
      }
    }
  }
}